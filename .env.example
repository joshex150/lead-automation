# ============================================================
# YEAN Lead Automation, server environment
# Copy to server/.env and fill in what you have.
#
# Almost everything here is optional. Provider credentials
# (Google Places, AI, email) are now configured from the
# dashboard Settings page and stored in MongoDB. These env
# vars act as a fallback and seed defaults, so you can run
# entirely from the dashboard if you prefer. The DB value
# always wins over the env value.
# ============================================================

# ---- Core (env only) ----
MONGODB_URI=mongodb://localhost:27017/yean_leads
PORT=4000
# Shared secret between the dashboard / n8n and the API.
# Leave empty to disable auth (local development only).
API_KEY=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins for the dashboard.
DASHBOARD_ORIGIN=http://localhost:3000

# ---- Google Places API (New) ----
# Or set it in the dashboard: Settings, Discovery.
GOOGLE_PLACES_API_KEY=

# ---- AI pitch writer ----
# Pick a provider in the dashboard (Settings, AI): OpenAI, Anthropic,
# NVIDIA, or any OpenAI-compatible endpoint. These env vars are the
# fallback when the dashboard AI provider is left on "Auto".
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=
# Force a provider (auto|openai|anthropic) when using env fallback.
PITCH_PROVIDER=auto
# Optional model override (defaults: gpt-4o-mini / claude-haiku-4-5-20251001).
PITCH_MODEL=
# Base URL for a custom OpenAI-compatible endpoint (Groq, Together, Ollama, vLLM).
AI_BASE_URL=

# ---- Email sending ----
# Pick a provider in the dashboard (Settings, Email): Gmail, Zoho, or Resend.
# These env vars are the fallback.

# Gmail (OAuth2, the only provider with real mailbox drafts).
# See docs/SETUP.md for the refresh-token walkthrough.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=hello@yean.tech
GMAIL_SENDER_NAME=YEAN Technologies

# Zoho Mail over SMTP (also works for any SMTP mailbox).
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=

# Resend (needs a verified sending domain).
RESEND_API_KEY=
# From address used by Zoho/Resend when none is set in the dashboard.
EMAIL_FROM=

# ---- Scheduler (dashboard-configurable too) ----
ENABLE_SCHEDULER=true
DISCOVERY_CRON=0 7 * * *
FOLLOWUP_CRON=0 9 * * *
TIMEZONE=Africa/Lagos

# ---- Pipeline behaviour (seed defaults; edit live in the dashboard) ----
SCORE_THRESHOLD=50
FOLLOW_UP_DAYS=4
MAX_CONTACT_ATTEMPTS=2
DAILY_EMAIL_CAP=25

# ---- Website checker tuning ----
CHECKER_TIMEOUT_MS=15000
CHECKER_MAX_REDIRECTS=10
CHECKER_CONCURRENCY=3

# ---- Dashboard (dashboard/.env.local) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_KEY=change-me-to-a-long-random-string
